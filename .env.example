APP_NAME=Clinical Copilot API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

GENERATION_API_KEY=your_first_groq_key_here
GENERATION_MODEL=llama-3.3-70b-versatile

FAITHFULNESS_API_KEY=your_second_groq_key_here
FAITHFULNESS_MODEL=llama-3.1-8b-instant

RELEVANCE_API_KEY=your_third_groq_key_here
RELEVANCE_MODEL=llama-3.1-8b-instant

TEMPERATURE=0.0
MAX_TOKENS=1024
TOP_K=8
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RETRY_BASE_DELAY=2.0
LLM_RETRY_MAX_DELAY=60.0
EVAL_SAMPLE_SIZE=10

CHUNK_SIZE=120
CHUNK_OVERLAP=20

GRAPH_NAME=clinical_copilot_agent
ENABLE_EVALUATION=true
DEFAULT_TOP_K=8