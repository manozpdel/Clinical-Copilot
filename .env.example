APP_NAME=Clinical Copilot API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

GENERATION_API_KEY=your_first_groq_key_here
GENERATION_MODEL=llama-3.3-70b-versatile

FAITHFULNESS_API_KEY=your_second_groq_key_here
FAITHFULNESS_MODEL=llama-3.1-8b-instant

RELEVANCE_API_KEY=your_third_groq_key_here
RELEVANCE_MODEL=llama-3.1-8b-instant

TEMPERATURE=0.0
MAX_TOKENS=1024
TOP_K=8
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RETRY_BASE_DELAY=2.0
LLM_RETRY_MAX_DELAY=60.0
EVAL_SAMPLE_SIZE=10

CHUNK_SIZE=120
CHUNK_OVERLAP=20

GRAPH_NAME=clinical_copilot_agent
ENABLE_EVALUATION=true
DEFAULT_TOP_K=8

MAX_TOOL_RETRIES=3
RETRY_DELAY=0.5
DEFAULT_TIMEOUT=10.0
ENABLE_TOOL_VALIDATION=true

TRANSCRIPTION_API_KEY=your_fourth_groq_key_here
GROQ_WHISPER_MODEL=whisper-large-v3
MAX_AUDIO_DURATION=300.0
MAX_CONVERSATION_HISTORY=20
ENABLE_MEMORY=true

API_VERSION=1.0.0
MAX_UPLOAD_SIZE=10000000
STATIC_FILES_PATH=frontend
ENABLE_FRONTEND=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinical_copilot
JWT_SECRET_KEY=your_long_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=300
DAILY_REQUEST_LIMIT=200
MONTHLY_TOKEN_LIMIT=2000000
MONTHLY_COST_LIMIT=50.0
MAX_REQUEST_SIZE_MB=10.0
TRUSTED_HOSTS=["*"]
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://accounts.google.com https://apis.google.com https://*.google.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://accounts.google.com; img-src 'self' data: https://fastapi.tiangolo.com https://*.googleusercontent.com https://*.google.com; connect-src 'self' https://accounts.google.com https://*.googleapis.com https://*.google.com; frame-src 'self' https://accounts.google.com https://*.google.com
ENABLE_SECURITY_HEADERS=true